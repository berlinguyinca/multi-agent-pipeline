{
  "name": "multi-agent-pipeline",
  "version": "0.1.0",
  "description": "Orchestrate AI tools through an iterative spec-refinement pipeline for one-shot TDD code generation",
  "type": "module",
  "bin": {
    "map": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "npm run test:core",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test:llm-agents": "node scripts/run-with-timeout.mjs 120000 vitest run tests/agents/llm-integration.test.ts",
    "test:llm-evidence": "node scripts/run-with-timeout.mjs 180000 vitest run tests/agents/evidence-smoke.test.ts",
    "test:e2e-cocaine-report": "node scripts/run-with-timeout.mjs 900000 vitest run tests/e2e/cocaine-report-command.test.ts",
    "test:all": "vitest run",
    "test:core": "vitest run --config vitest.core.config.ts",
    "test:tui": "node scripts/run-with-timeout.mjs 60000 vitest run --config vitest.tui.config.ts",
    "test:spike": "node scripts/run-with-timeout.mjs 60000 vitest run tests/spike",
    "test:ci": "npm run typecheck && npm run test:core && npm run test:tui"
  },
  "keywords": [
    "ai",
    "pipeline",
    "tdd",
    "cli",
    "tui",
    "claude",
    "codex",
    "ollama"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "chalk": "^5.4.0",
    "diff": "^8.0.0",
    "marked": "^15.0.0",
    "neo-blessed": "^0.2.0",
    "xstate": "^5.28.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
