{
  "name": "multi-agent-pipeline",
  "version": "0.1.0",
  "description": "Orchestrate AI tools through an iterative spec-refinement pipeline for one-shot TDD code generation",
  "type": "module",
  "bin": {
    "map": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "pipeline",
    "tdd",
    "cli",
    "tui",
    "claude",
    "codex",
    "ollama"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xstate/react": "^6.1.0",
    "chalk": "^5.4.0",
    "diff": "^8.0.0",
    "ink": "^7.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.0",
    "react": "^19.2.0",
    "xstate": "^5.28.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
