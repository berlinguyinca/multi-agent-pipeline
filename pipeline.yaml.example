# MAP Pipeline Configuration
# Copy this to pipeline.yaml in your project root or ~/.map/pipeline.yaml

agents:
  spec:
    adapter: claude          # claude | codex | ollama
    # model: deepseek-coder  # required for ollama, ignored for others
  review:
    adapter: codex
  qa:
    adapter: ollama
    model: qwen              # used for spec QA and code QA
  execute:
    adapter: ollama
    model: gemma4:26b        # implementation and QA-driven fixes
  docs:
    adapter: claude          # final Markdown documentation update

router:
  adapter: ollama
  model: gemma4:26b
  maxSteps: 10
  maxStepRetries: 1         # Keep local-model retries bounded; timeout retries double this budget
  stepTimeoutMs: 5m         # Initial per-step timeout; retry doubles this to handle slow local agents
  timeoutMs: 30s

agentConsensus:
  enabled: false            # Opt in only when extra quality is worth slower local-model runs
  runs: 3
  outputTypes: [answer, data, presentation]
  minSimilarity: 0.35
  perAgent:
    researcher:
      enabled: true
      runs: 3
      outputTypes: [answer]
      minSimilarity: 0.35
    classyfire-taxonomy-classifier:
      enabled: true
      runs: 3
      outputTypes: [answer]
      minSimilarity: 0.35
    usage-classification-tree:
      enabled: true
      runs: 3
      outputTypes: [answer]
      minSimilarity: 0.35
  fileOutputs:
    enabled: false          # Opt in for implementation consensus; can be slow on local models
    runs: 3
    isolation: git-worktree
    keepWorktreesOnFailure: true
    verificationCommands:
      - npm run typecheck
      - npm run test:core
    selection: best-passing-minimal-diff

agentCreation:
  adapter: ollama
  model: gemma4:26b

agentOverrides:
  output-formatter:
    enabled: false
  implementation-coder:
    model: gemma4:26b
  release-readiness-reviewer:
    enabled: true

ollama:
  host: http://localhost:11434

quality:
  maxSpecQaIterations: 3
  maxCodeQaIterations: 3

headless:
  totalTimeoutMs: 60m
  inactivityTimeoutMs: 10m
  pollIntervalMs: 10s

# Output directory for generated projects
outputDir: ./output

# Auto-commit at stage boundaries for cancel/resume
gitCheckpoints: true

# Generate pipeline execution summary at the end
generateAgentSummary: true   # Generate AGENTS_SUMMARY.md after each pipeline completes
