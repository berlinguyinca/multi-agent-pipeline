# MAP Pipeline Configuration
# Copy this to pipeline.yaml in your project root or ~/.map/pipeline.yaml

agents:
  spec:
    adapter: claude          # claude | codex | ollama
    # model: deepseek-coder  # required for ollama, ignored for others
  review:
    adapter: codex
  qa:
    adapter: ollama
    model: qwen              # used for spec QA and code QA
  execute:
    adapter: ollama
    model: gemma4            # implementation and QA-driven fixes
  docs:
    adapter: claude          # final Markdown documentation update

ollama:
  host: http://localhost:11434

quality:
  maxSpecQaIterations: 3
  maxCodeQaIterations: 3

# Output directory for generated projects
outputDir: ./output

# Auto-commit at stage boundaries for cancel/resume
gitCheckpoints: true
